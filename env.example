# ===========================================
# Meallion Voice AI - Environment Configuration
# ===========================================

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false
LOG_LEVEL=INFO

# ===========================================
# LiveKit Configuration
# ===========================================
# For local development, use ws://localhost:7880
# For production, use your LiveKit Cloud URL
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# ===========================================
# ElevenLabs Configuration (Elena Voice)
# ===========================================
ELEVENLABS_API_KEY=sk_8189136fc2caf7517e7bdc9a0053df0795082599462b37b9
ELEVENLABS_VOICE_ID=aTP4J5SJLQl74WTSRXKW
# Use eleven_multilingual_v2 for Greek, eleven_turbo_v2 for English-only
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_VOICE_STABILITY=0.45
ELEVENLABS_VOICE_SIMILARITY=0.80
ELEVENLABS_VOICE_SPEED=0.60

# ===========================================
# OpenAI Configuration
# ===========================================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# ===========================================
# Groq Configuration (Optional - 10x faster than OpenAI)
# ===========================================
# Get your API key from https://console.groq.com/
# Select provider and model from Admin Panel > Settings > LLM Configuration
GROQ_API_KEY=your_groq_api_key_here

# ===========================================
# Shopify Configuration
# ===========================================
# Get your access token from Shopify Admin > Settings > Apps > Develop apps
SHOPIFY_STORE_URL=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=your_shopify_access_token_here
# Collaboration code (for reference): 4483

# ===========================================
# Yuboto SIP Configuration (Greek VoIP Provider)
# ===========================================
# Get credentials from https://services.yuboto.com/mynumber/Index.aspx
YUBOTO_SIP_SERVER=sip.yuboto-telephony.gr
YUBOTO_SIP_USERNAME=your_yuboto_username
YUBOTO_SIP_PASSWORD=your_yuboto_password
YUBOTO_PHONE_NUMBER=+302XXXXXXXXX
# Optional: restrict inbound SIP traffic to known Yuboto IPs (comma-separated)
YUBOTO_ALLOWED_IPS=89.38.105.35/32

# ===========================================
# Email Configuration (Support Tickets)
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_USE_TLS=true
SUPPORT_EMAIL=support@meallion.com

# ===========================================
# Database Configuration
# ===========================================
DATABASE_URL=sqlite+aiosqlite:///./data/conversations.db

# ===========================================
# PostgreSQL Configuration (Admin Dashboard)
# ===========================================
# Connection URL for PostgreSQL database (works with any Postgres: Supabase, Neon, local, etc.)
POSTGRES_URL=postgresql+asyncpg://postgres:password@localhost:5432/meallion

# ===========================================
# Admin Dashboard Configuration
# ===========================================
ADMIN_EMAIL=admin@vakmedia.co
ADMIN_PASSWORD=change-this-password
ADMIN_JWT_SECRET=your-jwt-secret-key-change-in-production
ADMIN_JWT_EXPIRY_HOURS=24

# ===========================================
# Security
# ===========================================
SECRET_KEY=your-secret-key-change-in-production
